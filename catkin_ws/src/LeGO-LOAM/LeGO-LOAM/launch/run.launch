<launch>
    
    <!--- Sim Time -->
    <param name="/use_sim_time" value="false" />

    <!--- Run Rviz-->
    <arg name="rviz" default="false" />
    <arg name="use_imu" default="false" />
    <arg name="lock_roll_pitch" default="true" />
    <arg name="disabled_imu_topic" default="/lego_loam/disabled_imu" />
    <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz" args="-d $(find lego_loam)/launch/test.rviz" />

    <!--- TF -->
    <node pkg="tf" type="static_transform_publisher" name="camera_init_to_map"  args="0 0 0 1.570795   0        1.570795 /map    /camera_init 10" />
    <node pkg="tf" type="static_transform_publisher" name="base_link_to_camera" args="0 0 0 -1.570795 -1.570795 0        /camera /base_link   10" />

    <!--- LeGO-LOAM -->    
    <node pkg="lego_loam" type="imageProjection"    name="imageProjection"    output="screen"/>
    <node pkg="lego_loam" type="featureAssociation" name="featureAssociation" output="screen">
        <param name="lock_roll_pitch" value="$(arg lock_roll_pitch)" />
        <remap unless="$(arg use_imu)" from="/imu/data" to="$(arg disabled_imu_topic)" />
    </node>
    <node pkg="lego_loam" type="mapOptmization"     name="mapOptmization"     output="screen">
        <param name="lock_roll_pitch" value="$(arg lock_roll_pitch)" />
        <remap unless="$(arg use_imu)" from="/imu/data" to="$(arg disabled_imu_topic)" />
    </node>
    <node pkg="lego_loam" type="transformFusion"    name="transformFusion"    output="screen">
        <param name="lock_roll_pitch" value="$(arg lock_roll_pitch)" />
    </node>

</launch>
